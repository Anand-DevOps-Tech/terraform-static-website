# ============================================================
# .gitignore — Terraform + Jenkins Project
# ============================================================

# ----- Terraform -----
# Local .terraform directories
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
tfplan

# Terraform variable files (may contain secrets)
*.tfvars
!terraform/terraform.tfvars.example

# Terraform lock file (include in version control)
# .terraform.lock.hcl

# ----- SSH Keys -----
*.pem
*.key
id_rsa*

# ----- Jenkins -----
# Jenkins workspace files
jenkins/workspace/

# ----- OS -----
.DS_Store
Thumbs.db
desktop.ini

# ----- IDE -----
.idea/
.vscode/
*.swp
*.swo
*~

# ----- Logs -----
*.log

# ----- Archives -----
*.tar.gz
*.zip
